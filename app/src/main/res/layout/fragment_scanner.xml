<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary">

    <!-- Stats Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="@color/primary_dark">

        <TextView
            android:id="@+id/tv_scanned_count"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="已扫描 0 个应用"
            android:textColor="@android:color/white"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tv_ad_found_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="发现 0 个广告域名"
            android:textColor="#FFD54F"
            android:textSize="12sp" />

    </LinearLayout>

    <!-- Search & Scan -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp">

        <androidx.appcompat.widget.SearchView
            android:id="@+id/search_view"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            app:queryHint="搜索应用..."
            app:iconifiedByDefault="false"
            app:searchIcon="@drawable/ic_search" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_scan_all"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="扫描全部"
            android:textAllCaps="false"
            app:icon="@drawable/ic_scan"
            android:layout_marginStart="8dp" />

    </LinearLayout>

    <!-- App Count -->
    <TextView
        android:id="@+id/tv_app_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="已安装 0 个应用"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:paddingHorizontal="16dp"
        android:layout_marginBottom="8dp" />

    <!-- Progress -->
    <ProgressBar
        android:id="@+id/progress_bar"
        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone" />

    <!-- App List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_apps"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="72dp" />

</LinearLayout>
